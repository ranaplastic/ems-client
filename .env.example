# =====================================================================
# EMS Client Portal — Environment configuration
# Copy this file to `.env` and adjust the values for your environment.
# NOTE: Vite only exposes variables prefixed with VITE_ to the browser.
# =====================================================================

# Active profile (Spring-style). Selects the backend base URL below.
#   dev  -> http://localhost:8080   (default when unset)
#   prod -> https://ems.ranaplastics.com
VITE_PROFILE=dev

# Optional explicit override. When set, this takes precedence over the
# profile's base URL. Must be HTTPS in production (GitHub Pages blocks mixed
# HTTP content). Leave empty to use the profile default (host + /api/v1).
VITE_API_BASE_URL=

# Passphrase used to encrypt session data kept in the browser (localStorage).
# Generate a long random value for production deployments.
VITE_STORAGE_SECRET=change-me-to-a-long-random-string

# Base path for GitHub Pages project site. Must match "/<repo-name>/".
# Leave as "/" for local dev or a custom-domain deployment.
VITE_BASE_PATH=/ems-client/

# Serve in-memory demo data instead of calling a real backend.
# Useful for previews/demos. Set to false in production. Demo login: 1001 / 9876543210
VITE_USE_MOCK=false
